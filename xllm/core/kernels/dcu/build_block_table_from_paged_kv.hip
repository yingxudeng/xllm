// Fill each row of block_table from CSR-format paged KV metadata.
// One block per sequence; threads within the block cooperatively copy
// page IDs to the corresponding row.
//
// block_table is pre-allocated to [B, total_pages] and pre-initialized
// to -1. This kernel only writes valid page indices; padding positions
// remain at -1.
//
// total_pages = paged_kv_indices.size(0) is the worst-case row width,
// available from tensor metadata without any GPU sync.
__global__ void build_block_table_kernel(
    const int32_t* __restrict__ indptr,
    const int32_t* __restrict__ indices,
    int32_t batch_size,
    int32_t total_pages,
    int32_t* __restrict__ block_table) {
  const int32_t seq_id = static_cast<int32_t>(blockIdx.x);
  if (seq_id >= batch_size) {
    return;
  }

  const int32_t start = indptr[seq_id];
  const int32_t end = indptr[seq_id + 1];
  const int32_t num_pages = end - start;
  if (num_pages <= 0) {
    return;
  }

  // Row pointer = base + seq_id * row_stride (row_stride = total_pages)
  int32_t* row = block_table + static_cast<int64_t>(seq_id) * total_pages;

  // Coalesced writes: thread j writes positions j, j+blockDim, j+2*blockDim.
  for (int32_t j = static_cast<int32_t>(threadIdx.x); j < num_pages;
       j += static_cast<int32_t>(blockDim.x)) {
    row[j] = indices[start + j];
  }
}

}  // namespace

torch::Tensor build_block_table_from_paged_kv_cuda(
    const torch::Tensor& paged_kv_indptr,
    const torch::Tensor& paged_kv_indices) {
  CHECK(paged_kv_indptr.is_cuda())
      << "paged_kv_indptr must be on a HIP/DCU device";
  CHECK(paged_kv_indices.is_cuda())
      << "paged_kv_indices must be on a HIP/DCU device";
  CHECK_EQ(paged_kv_indptr.dim(), 1);
  CHECK_EQ(paged_kv_indices.dim(), 1);
  CHECK(paged_kv_indptr.is_contiguous());
  CHECK(paged_kv_indices.is_contiguous());

  // Accept int32 or int64; the kernel operates on int32.
  torch::Tensor indptr = paged_kv_indptr.scalar_type() == torch::kInt32
                             ? paged_kv_indptr
                             : paged_kv_indptr.to(torch::kInt32);
  torch::Tensor indices = paged_kv_indices.scalar_type() == torch::kInt32
                              ? paged_kv_indices
                              : paged_kv_indices.to(torch::kInt32);

  CHECK_GE(indptr.size(0), 2);
  CHECK_LE(indptr.size(0) - 1, INT32_MAX);
  CHECK_LE(indices.size(0), INT32_MAX);
  const int32_t batch_size = static_cast<int32_t>(indptr.size(0) - 1);
  CHECK_GT(batch_size, 0) << "batch_size must be positive";

  // total_pages comes from tensor metadata, so no GPU sync is needed.
  // It is the worst-case row width: no single sequence can own more pages
  // than exist in total. The flash attention kernel only reads up to the
  // per-sequence page count (governed by seqused_k), so extra -1 columns
  // are never accessed.
  const int32_t total_pages = static_cast<int32_t>(indices.size(0));
  const int32_t max_pages = std::max<int32_t>(total_pages, 1);

  const at::hip::OptionalHIPGuardMasqueradingAsCUDA device_guard(indptr.device());
  const hipStream_t stream =
      c10::hip::getCurrentHIPStreamMasqueradingAsCUDA(indptr.get_device());

  // Allocate without initialization, then memset to -1 via the hardware
  // fill engine (not a kernel launch). 0xFF repeated in each int32 byte
  // yields 0xFFFFFFFF = -1 in two's complement.
  torch::Tensor block_table = torch::empty(
      {batch_size, max_pages},
      torch::TensorOptions().dtype(torch::kInt32).device(indptr.device()));

  const hipError_t memset_status =
      hipMemsetAsync(block_table.data_ptr(),
                     0xFF,
                     static_cast<size_t>(batch_size) * max_pages *
                         sizeof(int32_t),
                     stream);
  CHECK_EQ(memset_status, hipSuccess)
      << "hipMemsetAsync failed: " << hipGetErrorString(memset_status);

  // Single kernel launch: fill valid page IDs.
  // Thread count = clamp(max_pages, 64, 256), at least two full wavefronts,
  // capped to avoid register pressure. Threads stride-loop when a row
  // has more pages than threads.
  int32_t threads = std::min<int32_t>(max_pages, 256);
  threads = std::max<int32_t>(threads, 64);

  hipLaunchKernelGGL(
      (build_block_table_kernel),
      dim3(batch_size),
      dim3(threads),
      0,
      stream,
      indptr.data_ptr<int32_t>(),
      indices.data_ptr<int32_t>(),
      batch_size,
      max_pages,
      block_table.data_ptr<int32_t>());
  C10_HIP_KERNEL_LAUNCH_CHECK();

  return block_table;
}

}  // namespace dcu
}  // namespace kernel
