{
  "block_size": 24,
  "max_cache_size": 1048576,
  "max_memory_utilization": 0.65,
  "kv_cache_dtype": "int8",
  "enable_prefix_cache": false,
  "xxh3_128bits_seed": 2048,
  "enable_xtensor": true,
  "phy_page_granularity_size": 4096,
  "max_tokens_per_batch": 2048,
  "max_seqs_per_batch": 32,
  "enable_schedule_overlap": true,
  "prefill_scheduling_memory_usage_threshold": 0.75,
  "enable_chunked_prefill": false,
  "max_tokens_per_chunk_for_prefill": 512,
  "chunked_match_frequency": 3,
  "use_zero_evict": true,
  "max_decode_token_per_sequence": 128,
  "priority_strategy": "priority",
  "use_mix_scheduler": true,
  "enable_online_preempt_offline": false,
  "aggressive_coeff": 1.5,
  "starve_threshold": 2.0,
  "enable_starve_prevent": false
}
